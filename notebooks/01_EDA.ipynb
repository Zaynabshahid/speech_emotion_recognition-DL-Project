# ---- Cell 3: Imports ----

import os
import sys
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import seaborn as sns
import librosa
import librosa.display
import IPython.display as ipd
import warnings

warnings.filterwarnings("ignore")
plt.rcParams.update({"figure.dpi": 120, "font.size": 11})

# Add src to path
sys.path.append("../src")  # adjust if running from notebook root
from data_loader import load_tess_paths, split_dataset, EMOTION_DISPLAY
from utils import set_seeds, plot_class_distribution

set_seeds(42)

# ---- Cell 4: Set your dataset path ----

# Update this to where your TESS folder lives
# If using Colab + Kaggle API:
#   !kaggle datasets download -d ejlok1/toronto-emotional-speech-set-tess
#   !unzip toronto-emotional-speech-set-tess.zip -d data/

DATA_ROOT = "data/TESS Toronto emotional speech set data"

df = load_tess_paths(DATA_ROOT)
print(f"\nTotal samples: {len(df)}")
print(df.head(10))

# ---- Cell 5: Class distribution ----

plot_class_distribution(df, save_dir="results/plots")

# Also print as table
print("\nClass distribution:")
print(df.groupby("emotion").size().reset_index(name="count").to_string(index=False))

# ---- Cell 6: Speaker distribution ----

fig, axes = plt.subplots(1, 2, figsize=(12, 4))

# By speaker
df["speaker"].value_counts().plot(kind="bar", ax=axes[0],
                                   color=["#4C72B0", "#DD8452"],
                                   edgecolor="white")
axes[0].set_title("Samples per Speaker")
axes[0].set_xlabel("Speaker")
axes[0].set_ylabel("Count")
axes[0].tick_params(rotation=0)

# By emotion per speaker
df.groupby(["speaker", "emotion"]).size().unstack().plot(
    kind="bar", ax=axes[1], edgecolor="white"
)
axes[1].set_title("Samples per Emotion per Speaker")
axes[1].set_xlabel("Speaker")
axes[1].set_ylabel("Count")
axes[1].legend(title="Emotion", bbox_to_anchor=(1.01, 1))
axes[1].tick_params(rotation=0)

plt.tight_layout()
plt.savefig("results/plots/speaker_distribution.png", dpi=150, bbox_inches="tight")
plt.show()

# ---- Cell 7: Audio file duration analysis ----

import soundfile as sf

durations = []
for path in df["path"].values[:200]:   # sample 200 for speed
    info = sf.info(path)
    durations.append(info.duration)

plt.figure(figsize=(8, 4))
plt.hist(durations, bins=30, color="#4C72B0", edgecolor="white")
plt.title("Audio Duration Distribution (sample of 200 files)")
plt.xlabel("Duration (seconds)")
plt.ylabel("Count")
plt.grid(alpha=0.3)
plt.tight_layout()
plt.savefig("results/plots/duration_distribution.png", dpi=150, bbox_inches="tight")
plt.show()
print(f"Mean duration : {np.mean(durations):.2f}s")
print(f"Min  duration : {np.min(durations):.2f}s")
print(f"Max  duration : {np.max(durations):.2f}s")

# ---- Cell 8: Visualize waveforms per emotion ----

from feature_extraction import load_audio, SAMPLE_RATE

emotions = sorted(df["emotion"].unique())
fig, axes = plt.subplots(len(emotions), 1, figsize=(14, 16))
fig.suptitle("Waveforms per Emotion Class", fontsize=14, fontweight="bold")

for ax, emo in zip(axes, emotions):
    sample_path = df[df["emotion"] == emo].iloc[0]["path"]
    y, sr = load_audio(sample_path)
    time_axis = np.linspace(0, len(y) / sr, len(y))
    ax.plot(time_axis, y, linewidth=0.6, color="#4C72B0")
    ax.set_ylabel(emo.title(), fontweight="bold")
    ax.set_xlim([0, 3])
    ax.grid(alpha=0.2)
    ax.set_yticks([])

axes[-1].set_xlabel("Time (seconds)")
plt.tight_layout()
plt.savefig("results/plots/waveforms_per_emotion.png", dpi=150, bbox_inches="tight")
plt.show()

# ---- Cell 9: Log-mel spectrograms per emotion ----

fig, axes = plt.subplots(2, 4, figsize=(16, 7))
fig.suptitle("Log-Mel Spectrograms per Emotion", fontsize=13, fontweight="bold")
axes = axes.flatten()

for i, emo in enumerate(emotions):
    sample_path = df[df["emotion"] == emo].iloc[0]["path"]
    y, sr = load_audio(sample_path)

    mel = librosa.feature.melspectrogram(y=y, sr=sr, n_mels=128)
    log_mel = librosa.power_to_db(mel, ref=np.max)

    img = librosa.display.specshow(log_mel, sr=sr, hop_length=512,
                                    x_axis="time", y_axis="mel", ax=axes[i])
    axes[i].set_title(EMOTION_DISPLAY.get(emo, emo.title()), fontweight="bold")
    axes[i].set_xlabel("")

fig.colorbar(img, ax=axes[:len(emotions)], format="%+2.0f dB",
             label="dB", shrink=0.6)
axes[len(emotions)].axis("off")   # hide empty subplot
plt.tight_layout()
plt.savefig("results/plots/mel_spectrograms_per_emotion.png", dpi=150, bbox_inches="tight")
plt.show()

# ---- Cell 10: MFCC visualization ----

fig, axes = plt.subplots(2, 4, figsize=(16, 7))
fig.suptitle("MFCC (first 13 coefficients) per Emotion", fontsize=13, fontweight="bold")
axes = axes.flatten()

for i, emo in enumerate(emotions):
    sample_path = df[df["emotion"] == emo].iloc[0]["path"]
    y, sr = load_audio(sample_path)
    mfcc = librosa.feature.mfcc(y=y, sr=sr, n_mfcc=13)
    librosa.display.specshow(mfcc, sr=sr, hop_length=512,
                              x_axis="time", ax=axes[i])
    axes[i].set_title(EMOTION_DISPLAY.get(emo, emo.title()), fontweight="bold")

axes[len(emotions)].axis("off")
plt.tight_layout()
plt.savefig("results/plots/mfcc_per_emotion.png", dpi=150, bbox_inches="tight")
plt.show()

# ---- Cell 11: Listen to audio samples (Colab interactive) ----

print("Sample audio clips per emotion:\n")
for emo in emotions:
    sample_path = df[df["emotion"] == emo].iloc[0]["path"]
    print(f"Emotion: {emo.upper()}")
    display(ipd.Audio(sample_path))

# ---- Cell 12: Train/Val/Test split ----

df_train, df_val, df_test = split_dataset(df)

print("\nSplit overview:")
for name, subset in [("Train", df_train), ("Val", df_val), ("Test", df_test)]:
    counts = subset["emotion"].value_counts().sort_index()
    print(f"\n{name} set:")
    for emo, cnt in counts.items():
        print(f"  {emo:<12}: {cnt}")

print("\nEDA complete. All plots saved to results/plots/")
